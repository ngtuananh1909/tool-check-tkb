# TDTU portal credentials
STUDENT_ID=your_student_id
PASSWORD=your_portal_password

# Optional override for semester selection on timetable page.
# Example: HK2/2025-2026
# If empty, bot auto-selects by date rule (Jan-Jul => HK2, Aug-Dec => HK1).
TARGET_SEMESTER=
# Number of future weeks to crawl from portal beyond current week.
# Example: 2 means crawl current week + next 2 weeks on each run.
CRAWLER_WEEKS_AHEAD=2
# Enable fallback source for exam crawler: portal first, then eLearning if no data.
EXAM_SOURCE_FALLBACK_ELEARNING=true
# Comma-separated exam type filters on portal exam page. Default: midterm,final
# Accepted aliases include: midterm, giuaky, gk, final, cuoiky, ck
TARGET_EXAM_TYPES=midterm,final

# eLearning login reuses STUDENT_ID and PASSWORD above.

# Supabase project credentials
SUPABASE_URL=https://your-project-ref.supabase.co
# Prefer service role key for server-side write operations (delete/insert).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Optional fallback key (can be anon, may fail writes if RLS blocks it).
SUPABASE_KEY=your_supabase_key

# Telegram bot credentials
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Telegram webhook settings (used by webhook_app.py)
# Public HTTPS URL that Telegram can reach, e.g. https://your-domain.example/telegram/webhook
TELEGRAM_WEBHOOK_URL=
# Secret token checked on incoming Telegram webhook requests
TELEGRAM_WEBHOOK_SECRET=

# Optional: Gemini key for natural-language appointment parsing
GEMINI_API_KEY=

# Optional: Google Calendar sync for today's classes + appointments
# Calendar ID example: your_email@gmail.com or abcdef123@group.calendar.google.com
# Do not use 'primary' with service accounts when you want to sync to your personal calendar.
GOOGLE_CALENDAR_ID=
# Number of weeks to keep weekly class recurrences synced to Google Calendar.
GOOGLE_CALENDAR_SYNC_WEEKS=16
# Feature flag for phase-based rollout to sync from concrete class sessions.
CALENDAR_USE_CLASS_SESSIONS=true
# Number of weeks ahead to materialize actual class sessions from weekly templates.
CLASS_SESSION_WEEKS_AHEAD=10
# Path to Google service account JSON file (recommended for local dev)
GOOGLE_SERVICE_ACCOUNT_FILE=
# Full service account JSON in one line (recommended for GitHub Actions secret)
# In GitHub Actions: set secrets.GOOGLE_SERVICE_ACCOUNT_JSON and do not use local absolute file paths.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Require Google Calendar sync on each run (default true)
GOOGLE_CALENDAR_REQUIRED=true

# Optional: timezone used to determine "today" (default: Asia/Ho_Chi_Minh)
APP_TIMEZONE=Asia/Ho_Chi_Minh

# Optional: contact list file for auto-adding attendees to Google Calendar timetable events
# Copy contact_example.txt to contact.txt and fill in real emails.
# Format: name - email (one per line)
# Schedule/class events → all contacts added as attendees
# Appointments → no attendees added from contact.txt
# Exams → no attendees added
