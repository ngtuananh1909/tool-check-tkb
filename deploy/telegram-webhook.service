[Unit]
Description=Telegram appointment webhook for tool-check-tkb
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/tool-check-tkb
EnvironmentFile=/opt/tool-check-tkb/.env
ExecStart=/opt/tool-check-tkb/.venv/bin/uvicorn webhook_app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

# Optional hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
